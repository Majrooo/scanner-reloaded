{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scanner Reloaded",
  "version": "0.1.0",
  "identifier": "com.majro.scanner-reloaded",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Scanner Reloaded",
        "width": 1400,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
